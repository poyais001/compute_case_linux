####################################################################################################
#
# TLSPH example:  elongate a 2d strip of aluminum py pulling its ends apart  
#
# unit sytem: GPa / mm / ms
#
####################################################################################################


####################################################################################################
# MATERIAL PARAMETERS
####################################################################################################
variable        E equal 300 # Young's modulus
variable        nu equal 0.22 # Poisson ratio
variable        rho equal 2500 # initial mass density
variable        q1 equal 0.06 # standard artificial viscosity linear coefficient
variable        q2 equal 0.0  # standard artificial viscosity quadratic coefficient
variable        hg equal 10.0 # hourglass control coefficient
variable        cp equal 1.0  # heat capacity of material -- not used here
variable        sigma_yield equal 0.499 # plastic yield stress
variable        contact_stiffness equal 0.2

variable        GTN_Q1 equal 0.22
variable        GTN_Q2 equal 0.49153
variable        GTN_fn equal 0.04
variable        GTN_sn equal 0.01
variable        GTN_epsn equal 0.5
variable        GTN_f0 equal 0.0001
variable        GTN_fcr equal 0.01
variable        GTN_fF equal 0.2
variable        GTN_komega equal 5.5
# variable        D1 equal 0.636
# variable        D2 equal 1.936
# variable        D3 equal -2.969
# variable        D4 equal -0.0140
# variable        D5 equal 1.014


####################################################################################################
# INITIALIZE LAMMPS
####################################################################################################
dimension       3
units			si
boundary        f f f # simulation box boundaries
atom_style      smd
atom_modify		map array
comm_modify     vel yes
comm_style      tiled
neigh_modify    every 10 delay 0 check yes # re-build neighbor list every 10 steps
newton          off

####################################################################################################
# CREATE INITIAL GEOMETRY
####################################################################################################

variable        l0 equal 0.0005 # lattice spacing for creating particles
lattice         sc ${l0}
region          box block -0.1 0.3 -0.1 0.2 -0.1 0.1 units box
create_box      2 box

region          glass_region block 0 0.08 0 0.02 0.0001 0.003 units box
create_atoms    1 region glass_region

region          groove_region block 0.03 0.0302 0 0.02 0.0028 0.003 units box
delete_atoms    region groove_region

region          upper_catcher_region block -0.001 0.025 0 0.02 0.0031 0.005 units box
create_atoms    2 region upper_catcher_region
region          lower_catcher_region block -0.001 0.025 0 0.02 -0.0019 0 units box
create_atoms    2 region lower_catcher_region
region          indenter_region block 0.07 0.08 0 0.02 0.0031 0.005 units box
create_atoms    2 region indenter_region

group           catcher region upper_catcher_region
group           catcher region lower_catcher_region
group           indenter region indenter_region
group           glass type 1

group           tlsph type 1
group           wall type 2

group           inte type 1 2

####################################################################################################
# DISCRETIZATION PARAMETERS
####################################################################################################
variable 	    h equal 2.01*${l0} # SPH smoothing kernel radius
variable 	    vol_one equal ${l0}^3 # volume of one particle -- assuming unit thickness
variable 	    skin equal ${h} # Verlet list range
neighbor        ${skin} bin
variable        cr equal ${l0}/2
set             group all smd/contact/radius ${cr}
set             group all volume ${vol_one}
set             group all smd/mass/density ${rho}
set             group all diameter ${h} # set SPH kernel radius

####################################################################################################
# DEFINE VELOCITY BOUNDARY CONDITIONS
####################################################################################################
fix             vel_catcher catcher smd/setvel 0 0 0
fix             vel_indenter indenter smd/setvel 0 0 -0.0001

####################################################################################################
# INTERACTION PHYSICS / MATERIAL MODEL
# We use polynomial EOS for the pressure and the Johnson Cook strength model
# An integration point fails (cannot support tension anymore) if the plastic strain exceeds 0.5.
####################################################################################################
pair_style      hybrid/overlay smd/tlsph smd/hertz 1
pair_coeff      1 1 smd/tlsph *COMMON ${rho} ${E} ${nu} ${q1} ${q2} ${hg} ${cp} &
                *STRENGTH_LINEAR &
                *FAILURE_MAX_PRINCIPAL_STRESS 0.5 &
                *EOS_LINEAR & 
                *END
pair_coeff      1 1 smd/hertz 1.1 0
pair_coeff      1 2 smd/hertz 1.1 0
pair_coeff      2 2 none
####################################################################################################
# TIME INTEGRATION
####################################################################################################
fix             dtfix all smd/adjust_dt 0.2 # dynamically adjust time increment every step
fix             integration_fix all smd/integrate_tlsph

####################################################################################################
# SPECIFY TRAJECTORY OUTPUT
####################################################################################################
compute         S tlsph smd/tlsph/stress # Cauchy stress tensor
compute         E tlsph smd/tlsph/strain # Green-Lagrange strain tensor
compute         nn tlsph smd/tlsph/num/neighs # number of neighbors for each particle
compute         p tlsph smd/plastic/strain
compute         damage tlsph smd/damage
compute         disp all displace/atom
compute         shape tlsph smd/tlsph/shape
compute         orient tlsph smd/tlsph/orientation

variable        etot equal c_alleint+ke+pe
dump            dump_id all custom 500 dump.LAMMPS &
                id type x y z &
                c_damage c_p  c_nn&
                vx vy vz &
                c_S[1] c_S[2] c_S[3] c_S[4] c_S[5] c_S[6] c_S[7] c_S[8] c_S[9] c_S[10] c_S[11] &
                c_E[1] c_E[2] c_E[3] c_E[4] c_E[5] c_E[6] c_E[7] c_E[8] c_E[9] c_E[10] c_E[11] &
                c_shape[1] c_shape[2] c_shape[3] &
                c_orient[1] c_orient[2] c_orient[3] c_orient[4] &
                c_disp[1] c_disp[2] c_disp[3] 
dump_modify     dump_id first yes

####################################################################################################
# STATUS OUTPUT
####################################################################################################
# variable stress equal 0.5*(f_velbot_fix[1]-f_veltop_fix[1])/20
# variable length equal xcm(top_atoms,x)-xcm(bot_atoms,x)
# variable strain equal (v_length-${length})/${length} # engineering strain
# fix stress_curve all print 10 "${strain} ${stress}" file stress_strain.dat screen no

thermo          100
thermo_style    custom step dt f_dtfix # v_strain

####################################################################################################
# RUN SIMULATION
####################################################################################################
#fix 2 all enforce2d
balance 1.1 rcb
fix balance_fix all balance 1000 1.1 rcb
run 150000
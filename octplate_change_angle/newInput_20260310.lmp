variable pull_angle equal 45 # 引張方向(0,45,90,135,-45)
variable key string octplate1_039_lmpels_pull${pull_angle}
shell mkdir dumps
shell mkdir dumps/${key}
log dumps/${key}/log.lmp

variable        E equal 2.0
variable        rho equal 7874
variable        nu equal 0.3
variable        q1 equal 0.06
variable        q2 equal 0.0
variable        hg equal 10.0
variable        cp equal 1.0
variable        contact_stiffness equal 0.2


dimension       3
units			si
boundary        sm sm sm
atom_style      smd
atom_modify		map array
comm_modify     vel yes
neigh_modify    every 10 delay 0 check yes
newton          off

variable 	    l0 equal 0.001036
read_data       octplate_pfrom1.036slim.data
group		    tlsph type 1
group fpart0+   id 2001 2098 2195 2292 2389 2486 2583 2680 2777 2874 2971 3068 3165 3262 3359 3456 3553 3650 3747 3844 3941 4038 4135 4232 4329 4426 4523 4620 4717 4814 4911 5008 5105 5202 5299 5396 5493 5590 5687 5784 5881 9786 9883 9980 10077 10174 10271 10368 10465 10562 10659 10756 10853 10950 11047 11144 11241 11338 11435 11532 11629 11726 11823 11920 12017 12114 12211 12308 12405 12502 12599 12696 12793 12890 12987 13084 13181 13278 13375 13472 13569 13666 17571 17668 17765 17862 17959 18056 18153 18250 18347 18444 18541 18638 18735 18832 18929 19026 19123 19220 19317 19414 19511 19608 19705 19802 19899 19996 20093 20190 20287 20384 20481 20578 20675 20772 20869 20966 21063 21160 21257 21354 21451 25356 25453 25550 25647 25744 25841 25938 26035 26132 26229 26326 26423 26520 26617 26714 26811 26908 27005 27102 27199 27296 27393 27490 27587 27684 27781 27878 27975 28072 28169 28266 28363 28460 28557 28654 28751 28848 28945 29042 29139 29236 33141 33238 33335 33432 33529 33626 33723 33820 33917 34014 34111 34208 34305 34402 34499 34596 34693 34790 34887 34984 35081 35178 35275 35372 35469 35566 35663 35760 35857 35954 36051 36148 36245 36342 36439 36536 36633 36730 36827 36924 37021
group fpart0-   id 1905 2002 2099 2196 2293 2390 2487 2584 2681 2778 2875 2972 3069 3166 3263 3360 3457 3554 3651 3748 3845 3942 4039 4136 4233 4330 4427 4524 4621 4718 4815 4912 5009 5106 5203 5300 5397 5494 5591 5688 5785 9690 9787 9884 9981 10078 10175 10272 10369 10466 10563 10660 10757 10854 10951 11048 11145 11242 11339 11436 11533 11630 11727 11824 11921 12018 12115 12212 12309 12406 12503 12600 12697 12794 12891 12988 13085 13182 13279 13376 13473 13570 17475 17572 17669 17766 17863 17960 18057 18154 18251 18348 18445 18542 18639 18736 18833 18930 19027 19124 19221 19318 19415 19512 19609 19706 19803 19900 19997 20094 20191 20288 20385 20482 20579 20676 20773 20870 20967 21064 21161 21258 21355 25260 25357 25454 25551 25648 25745 25842 25939 26036 26133 26230 26327 26424 26521 26618 26715 26812 26909 27006 27103 27200 27297 27394 27491 27588 27685 27782 27879 27976 28073 28170 28267 28364 28461 28558 28655 28752 28849 28946 29043 29140 33045 33142 33239 33336 33433 33530 33627 33724 33821 33918 34015 34112 34209 34306 34403 34500 34597 34694 34791 34888 34985 35082 35179 35276 35373 35470 35567 35664 35761 35858 35955 36052 36149 36246 36343 36440 36537 36634 36731 36828 36925
group fpart90+  id 7745 7746 7747 7748 7749 7750 7751 7752 7753 7754 7755 7756 7757 7758 7759 7760 7761 7762 7763 7764 7765 7766 7767 7768 7769 7770 7771 7772 7773 7774 7775 7776 7777 7778 7779 7780 7781 7782 7783 7784 7785 15530 15531 15532 15533 15534 15535 15536 15537 15538 15539 15540 15541 15542 15543 15544 15545 15546 15547 15548 15549 15550 15551 15552 15553 15554 15555 15556 15557 15558 15559 15560 15561 15562 15563 15564 15565 15566 15567 15568 15569 15570 23315 23316 23317 23318 23319 23320 23321 23322 23323 23324 23325 23326 23327 23328 23329 23330 23331 23332 23333 23334 23335 23336 23337 23338 23339 23340 23341 23342 23343 23344 23345 23346 23347 23348 23349 23350 23351 23352 23353 23354 23355 31100 31101 31102 31103 31104 31105 31106 31107 31108 31109 31110 31111 31112 31113 31114 31115 31116 31117 31118 31119 31120 31121 31122 31123 31124 31125 31126 31127 31128 31129 31130 31131 31132 31133 31134 31135 31136 31137 31138 31139 31140 38885 38886 38887 38888 38889 38890 38891 38892 38893 38894 38895 38896 38897 38898 38899 38900 38901 38902 38903 38904 38905 38906 38907 38908 38909 38910 38911 38912 38913 38914 38915 38916 38917 38918 38919 38920 38921 38922 38923 38924 38925

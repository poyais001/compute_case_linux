group fpart45+  id 5881 5976 6069 6160 6249 6336 6421 6504 6585 6664 6741 6816 6889 6960 7029 7096 7161 7224 7285 7344 7401 7456 7509 7560 7609 7656 7701 7744 7785 13666 13761 13854 13945 14034 14121 14206 14289 14370 14449 14526 14601 14674 14745 14814 14881 14946 15009 15070 15129 15186 15241 15294 15345 15394 15441 15486 15529 15570 21451 21546 21639 21730 21819 21906 21991 22074 22155 22234 22311 22386 22459 22530 22599 22666 22731 22794 22855 22914 22971 23026 23079 23130 23179 23226 23271 23314 23355 29236 29331 29424 29515 29604 29691 29776 29859 29940 30019 30096 30171 30244 30315 30384 30451 30516 30579 30640 30699 30756 30811 30864 30915 30964 31011 31056 31099 31140 37021 37116 37209 37300 37389 37476 37561 37644 37725 37804 37881 37956 38029 38100 38169 38236 38301 38364 38425 38484 38541 38596 38649 38700 38749 38796 38841 38884 38925
group fpart45-  id 1 42 85 130 177 226 277 330 385 442 501 562 625 690 757 826 897 970 1045 1122 1201 1282 1365 1450 1537 1626 1717 1810 1905 7786 7827 7870 7915 7962 8011 8062 8115 8170 8227 8286 8347 8410 8475 8542 8611 8682 8755 8830 8907 8986 9067 9150 9235 9322 9411 9502 9595 9690 15571 15612 15655 15700 15747 15796 15847 15900 15955 16012 16071 16132 16195 16260 16327 16396 16467 16540 16615 16692 16771 16852 16935 17020 17107 17196 17287 17380 17475 23356 23397 23440 23485 23532 23581 23632 23685 23740 23797 23856 23917 23980 24045 24112 24181 24252 24325 24400 24477 24556 24637 24720 24805 24892 24981 25072 25165 25260 31141 31182 31225 31270 31317 31366 31417 31470 31525 31582 31641 31702 31765 31830 31897 31966 32037 32110 32185 32262 32341 32422 32505 32590 32677 32766 32857 32950 33045
group fpart135+ id 5785 5882 5977 6070 6161 6250 6337 6422 6505 6586 6665 6742 6817 6890 6961 7030 7097 7162 7225 7286 7345 7402 7457 7510 7561 7610 7657 7702 7745 13570 13667 13762 13855 13946 14035 14122 14207 14290 14371 14450 14527 14602 14675 14746 14815 14882 14947 15010 15071 15130 15187 15242 15295 15346 15395 15442 15487 15530 21355 21452 21547 21640 21731 21820 21907 21992 22075 22156 22235 22312 22387 22460 22531 22600 22667 22732 22795 22856 22915 22972 23027 23080 23131 23180 23227 23272 23315 29140 29237 29332 29425 29516 29605 29692 29777 29860 29941 30020 30097 30172 30245 30316 30385 30452 30517 30580 30641 30700 30757 30812 30865 30916 30965 31012 31057 31100 36925 37022 37117 37210 37301 37390 37477 37562 37645 37726 37805 37882 37957 38030 38101 38170 38237 38302 38365 38426 38485 38542 38597 38650 38701 38750 38797 38842 38885
group fpart135- id 41 84 129 176 225 276 329 384 441 500 561 624 689 756 825 896 969 1044 1121 1200 1281 1364 1449 1536 1625 1716 1809 1904 2001 7826 7869 7914 7961 8010 8061 8114 8169 8226 8285 8346 8409 8474 8541 8610 8681 8754 8829 8906 8985 9066 9149 9234 9321 9410 9501 9594 9689 9786 15611 15654 15699 15746 15795 15846 15899 15954 16011 16070 16131 16194 16259 16326 16395 16466 16539 16614 16691 16770 16851 16934 17019 17106 17195 17286 17379 17474 17571 23396 23439 23484 23531 23580 23631 23684 23739 23796 23855 23916 23979 24044 24111 24180 24251 24324 24399 24476 24555 24636 24719 24804 24891 24980 25071 25164 25259 25356 31181 31224 31269 31316 31365 31416 31469 31524 31581 31640 31701 31764 31829 31896 31965 32036 32109 32184 32261 32340 32421 32504 32589 32676 32765 32856 32949 33044 33141

displace_atoms_smd all rotate 0 0 0 0 0 1 45 units box

variable 	h equal 2.01*${l0}
variable 	vol_one equal ${l0}^3
variable 	skin equal ${h}
neighbor    ${skin} bin
set 		group all volume ${vol_one}
set         group all smd/mass/density ${rho}
set 		group all diameter ${h}
set         group all smd/contact/radius ${l0}

variable 	    vel_max equal 0.001 # pull velocity
variable 	    vel_x_max equal ${vel_max}*cos(${pull_angle}*PI/180)
variable 	    vel_y_max equal ${vel_max}*sin(${pull_angle}*PI/180)
print "# vel_max: ${vel_max} (${vel_x_max},${vel_y_max})"
variable        vel_up equal ${vel_max}*(1.0-exp(-0.01*time))
variable        vel_down equal -${vel_max}*(1.0-exp(-0.01*time))
variable 	    vel_x_up equal v_vel_up*cos(${pull_angle}*PI/180)
variable 	    vel_x_down equal -v_vel_x_up
variable 	    vel_y_up equal v_vel_up*sin(${pull_angle}*PI/180)
variable 	    vel_y_down equal -v_vel_y_up
# fix             fix_right fpart${pull_angle}+ smd/setvel v_vel_x_up v_vel_y_up 0
# fix             fix_left fpart${pull_angle}- smd/setvel v_vel_x_down v_vel_y_down 0

fix             fix_right fpart0+ smd/setvel v_vel_x_up v_vel_y_up 0
fix             fix_left fpart0- smd/setvel v_vel_x_down v_vel_y_down 0


# pair_style      hybrid/overlay smd/tlsph smd/hertz 1.0
# pair_coeff      1 1 smd/tlsph *COMMON ${rho} ${E} ${nu} ${q1} ${q2} ${hg} ${cp} &
#                 *STRENGTH_LINEAR &
#                 *EOS_LINEAR & 
#                 *END
# pair_coeff      1 1 smd/hertz ${contact_stiffness} 0

pair_style      smd/tlsph
pair_coeff      1 1 *COMMON ${rho} ${E} ${nu} ${q1} ${q2} ${hg} ${cp} &
                *STRENGTH_LINEAR &
                *EOS_LINEAR & 
                *END


fix             dtfix tlsph smd/adjust_dt 0.1
fix             integration_fix tlsph smd/integrate_tlsph


compute         S tlsph smd/tlsph/stress
compute         E tlsph smd/tlsph/strain
compute         nn all smd/tlsph/num/neighs
compute         p tlsph smd/plastic/strain
compute         damage tlsph smd/damage
compute         disp all displace/atom
compute         shape tlsph smd/tlsph/shape
compute         orient tlsph smd/tlsph/orientation

dump            dump_id all custom 100 atomdump &
                id type x y z &
                c_damage c_p  c_nn&
                vx vy vz &
                c_S[1] c_S[2] c_S[3] c_S[4] c_S[5] c_S[6] c_S[7] c_S[8] c_S[9] c_S[10] c_S[11] &
                c_E[1] c_E[2] c_E[3] c_E[4] c_E[5] c_E[6] c_E[7] c_E[8] c_E[9] c_E[10] c_E[11] &
                c_shape[1] c_shape[2] c_shape[3] &
                c_orient[1] c_orient[2] c_orient[3] c_orient[4] &
                c_disp[1] c_disp[2] c_disp[3] c_disp[4]
dump_modify     dump_id first yes


compute xmax_right fpart${pull_angle}+ reduce max c_disp[4]
variable disp_right equal c_xmax_right

thermo          100
thermo_style    custom step dt time f_dtfix v_disp_right
variable        dat_step equal step
variable        dat_time equal time
fix dat_timestep all print 1000 "${dat_step},${dat_time}" file dumps/${key}/timesteps.csv title "step,time" screen no


run 30000

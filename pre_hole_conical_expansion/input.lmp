####################################################################################################
#
# ULSPH example: water flow through a complex geometry read from a .STL file
#
# The boundary dump file (see below) can be converted into VTK format using the conversion
# tool dump2vtk_tris from the tools/smd directory.
#
# unit system: GPa / mm / ms
#
####################################################################################################

####################################################################################################
# MATERIAL PARAMETERS
####################################################################################################
variable        E equal 200.0 # Young's modulus
variable        nu equal 0.33 # Poisson ratio
variable        rho equal 7750 # initial mass density
variable        q1 equal 0.06 # standard artificial viscosity linear coefficient
variable        q2 equal 0.0  # standard artificial viscosity quadratic coefficient
variable        hg equal 10.0 # hourglass control coefficient
variable        cp equal 1.0  # heat capacity of material -- not used here
variable        sigma_yield equal 0.1 # plastic yield stress
variable        hardening_para equal 5
variable        contact_stiffness equal 1

####################################################################################################
# INITIALIZE LAMMPS
####################################################################################################
dimension       3
units           si
boundary        f f m # simulation box boundaries
atom_style      smd
atom_modify	map array
comm_modify     vel yes
comm_style      tiled
neigh_modify    every 10 delay 0 check yes exclude type 2 2 one 50000 page 500000
newton          off

####################################################################################################
# CREATE INITIAL GEOMETRY
####################################################################################################
variable        l0 equal 2 # lattice spacing for creating particles
lattice         sc ${l0}
region          box block -60 60 -60 60 -20 40 units box
create_box      3 box
region          particles block -40 40 -40 40 10.1 19.9 units box
create_atoms    1 region particles
# group           steel type 1
group           tlsph type 1

# region          indenter cylinder z 0 0 14.9 20 25 units box
# create_atoms    3 region indenter
# group           indenter type 3

group           inte type 1 3

####################################################################################################
# DISCRETIZATION PARAMETERS
####################################################################################################
variable        h equal 2.01*${l0} # SPH smoothing kernel radius
variable        vol_one equal ${l0}^3 # volume of one particle -- assuming unit thickness
variable        skin equal 0.1*${h} # Verlet list range
neighbor        ${skin} bin
variable        cr equal ${l0}/2
set             group all smd/contact/radius ${cr}
set             group all volume ${vol_one}
set             group all smd/mass/density ${rho}
set             group all diameter ${h} # set SPH kernel radius

####################################################################################################
# DEFINE GRAVITY BOUNDARY CONDITION
####################################################################################################
# fix             gfix all gravity 0.01 vector 0.0 0.0 -1.
# fix             fix_vel indenter smd/setvel 0 0 -0.001

####################################################################################################
# INTERACTION PHYSICS / MATERIAL MODEL
# We use polynomial EOS for the pressure and the Johnson Cook strength model
# An integration point fails (cannot support tension anymore) if the plastic strain exceeds 0.5.
####################################################################################################
pair_style      hybrid/overlay smd/tri_surface 1.5 smd/tlsph smd/hertz 1.5
pair_coeff      1 1 smd/tlsph *COMMON ${rho} ${E} ${nu} ${q1} ${q2} ${hg} ${cp} &
                *STRENGTH_LINEAR_PLASTIC ${sigma_yield} 0.1 &
                *FAILURE_MAX_PRINCIPAL_STRAIN 0.2 &
                *EOS_LINEAR & 
                *END
pair_coeff      2 2 none
pair_coeff      1 2 smd/tri_surface ${contact_stiffness}
pair_coeff      3 3 none
pair_coeff      1 3 smd/hertz 1.5 0
pair_coeff      2 3 none

####################################################################################################
# LOAD STL SURFACE
####################################################################################################
fix             fix_stl_board all smd/wall_surface board_32.stl 2 65535
fix             fix_stl_pusher all smd/wall_surface pusher.stl 2 65536
# fix             fix_stl_board all smd/wall_surface board_70.stl 2 65535
# fix             fix_stl_pusher all smd/wall_surface punch.stl 2 65536
run             0 # This is important! Always run for 0 timesteps directly after loading STL file!
group           board molecule 65535
group           pusher molecule 65536
group           stl_particle type 2

####################################################################################################
# TIME INTEGRATION
####################################################################################################
fix             force_fix board setforce 0 0 0
fix             stl_move pusher smd/move_tri_surf *LINEAR 0.0 0.0 -0.0005
fix             dtfix all smd/adjust_dt 0.1 # dynamically adjust time increment every step
fix             integration_fix tlsph smd/integrate_tlsph

####################################################################################################
# SPECIFY TRAJECTORY OUTPUT
####################################################################################################
variable        dumpFreq equal 1000
compute         epsdot tlsph smd/plastic/strain/rate
compute         S tlsph smd/tlsph/stress # Cauchy stress tensor
compute         D tlsph smd/tlsph/strain/rate
compute         E tlsph smd/tlsph/strain # Green-Lagrange strain tensor
compute         nn tlsph smd/tlsph/num/neighs # number of neighbors for each particle
compute         p tlsph smd/plastic/strain
compute         surface_coords stl_particle smd/triangle/vertices

compute         damage tlsph smd/damage
compute         disp tlsph displace/atom
compute         shape tlsph smd/tlsph/shape
compute         orient tlsph smd/tlsph/orientation

dump            dump_id all custom ${dumpFreq} atomdump &
                id type x y z vx vy vz c_p c_nn proc c_damage &
                c_S[1] c_S[2] c_S[3] c_S[4] c_S[5] c_S[6] c_S[7] c_S[8] c_S[9] c_S[10] c_S[11] &
                c_E[1] c_E[2] c_E[3] c_E[4] c_E[5] c_E[6] c_E[7] c_E[8] c_E[9] c_E[10] c_E[11] &
                c_shape[1] c_shape[2] c_shape[3] &
                c_orient[1] c_orient[2] c_orient[3] c_orient[4] &
                c_disp[1] c_disp[2] c_disp[3] c_disp[4]
dump_modify     dump_id first yes

####################################################################################################
# STATUS OUTPUT
####################################################################################################
compute         eint tlsph smd/internal/energy
compute         alleint tlsph reduce sum c_eint
# variable        etot equal pe+ke+c_alleint+f_gfix # total energy of the system
thermo          100
thermo_style    custom step dt f_dtfix pe ke #v_etot
thermo_modify   flush yes

####################################################################################################
# RUN SIMULATION
####################################################################################################
balance          1.1 rcb
fix              balance_fix all balance 200 1.1 rcb
run              200000


unfix             fix_stl_board
unfix             fix_stl_pusher

unfix             force_fix
unfix             stl_move

# compress会改变粒子顺序，tlsph的邻居关系不能与delete_atoms同时更新，因此必须关闭compress
delete_atoms group stl_particle compress no
region hole_atoms block -50 50 -50 50 -20 9.9 units box
# 删除tlsph粒子会导致particle missing
# delete_atoms region hole_atoms compress no

fix             fix_stl_board all smd/wall_surface board_70.stl 2 65535
fix             fix_stl_punch all smd/wall_surface punch.stl 2 65536
run             0
group           board molecule 65535
group           punch molecule 65536
group           stl_particle type 2

fix             force_fix board setforce 0 0 0
fix             stl_move punch smd/move_tri_surf *LINEAR 0.0 0.0 -0.0005

run 300000